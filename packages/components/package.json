{
  "name": "@star-dream051118/drawings-ui",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/drawings-ui.cjs",
  "module": "./dist/drawings-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/drawings-ui.js",
      "require": "./dist/drawings-ui.cjs",
