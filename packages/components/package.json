  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && sass src/fonts.scss dist/fonts.css --no-source-map && node -e \"require('fs').copyFileSync('src/fonts/mc_font.ttf','dist/mc_font.ttf')\""
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "sass": "^1.80.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^3.9.0",
    "vue": "^3.5.0"
  }
}
